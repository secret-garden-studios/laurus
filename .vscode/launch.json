{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Debug Server-side",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "args": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "- Local: {2,3}http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s"
      },
      "env": {
        "NODE_OPTIONS": "--inspect"
      }
    }
  ]
}
